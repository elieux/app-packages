_rmmsdll() {
    local ms

    ms=("msvbvm[0-9]+"
        "ucrtbase"
        "mfcm?[0-9]+[a-z]+"
        "msvc[rp][0-9]+(_([0-9]|codecvt_ids|atomic_wait))?"
        "vc([ao]mp|corlib|runtime)[0-9]+(_([0-9]|threads))?"
        "concrt[0-9]+"
        "pgort[0-9]+"
        "api-ms-win-[0-9a-z-]+")
    find "${1}" -iname '*.dll' | grep -Eif <(for m in "${ms[@]}"; do echo "/${m}[.]dll$"; done) | xargs -r rm
}

prepare() {
    7z x -y -bd "asx64.exe" -o"asx64.dir" > /dev/null
}

package() {
    local a="${pkgdir}/apps/${_realname}"
    mkdir -p "${a}"
    cp -R "asx64.dir"/* "${a}"
    cp -R "dbviewer/x64"/* "${a}"
    cp -R "tar-plugin-x64"/* "${a}/plugins/tar"
    cp "7z-extra/x64/7za.dll" "${a}/plugins/7zip"
    cp "unrardll/x64/UnRAR64.dll" "${a}/plugins/unrar/unrar.dll"
    rm -R "${a}/remove" "${a}/x64" "${a}"/setup.{exe,inf}
    _rmmsdll "${a}"
}
