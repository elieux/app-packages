_chocover() {
    # 20201112.0512.0 -> 2020.11.12.05.12
    # 20201112.0512 -> 2020.11.12.05.12
    echo "${1}" | sed -r 's/^([0-9]{4})([0-9]{2})([0-9]{2})[.]([0-9]{2})([0-9]{2})([.]0)?$/\1.\2.\3.\4.\5/'
}

_extract_subdir() {
    local _file="$(get_filename "${1}")"
    local _dir="${_file%.*}"
    if type bsdtar | head -1 | grep -q 'is a function'
    then
        local _original_bsdtar="$(type bsdtar | tail +2)"
    fi
    bsdtar() {
        local _extra_args=()
        if [ "${1}" = "-xf" ]
        then
            mkdir -p "${_dir}"
            _extra_args=(-C "${_dir}")
        fi
        /usr/bin/bsdtar "${_extra_args[@]}" "${@}"
    }
    extract_file "${_file}"
    unset -f bsdtar
    eval "${_original_bsdtar}"
}

extract_https@subdir() {
    _extract_subdir "${@}"
}

download_https@subdir() {
    download_file "${1/@subdir:/:}"
}

_realver=2026-04-20_19-04
_realname=x64dbg
_choconame=x64dbg.portable
pkgbase="app-${_realname}"
pkgname=("app-x86_64-${_realname}")
epoch=1
pkgver=2026.04.20
pkgrel=1
pkgdesc="An open-source x64/x32 debugger for Windows"
arch=('any')
url="https://x64dbg.com/"
license=('GPL3')
provides=("${pkgbase}")
options=(!strip)
source=("snapshot.zip::https@subdir://github.com/x64dbg/x64dbg/releases/download/${pkgver}/snapshot_${_realver}.zip")
sha512sums=('ac3966401367b6cb52c24381d8aad86066eb94d10b0e5553e54a7359c3a910a229e6917495fd4c2f147612a4e9838fa2970a9a58be5fb6918de3b2391fd6d027')

_rmmsdll() {
    local ms

    ms=("msvbvm[0-9]+"
        "ucrtbase"
        "mfcm?[0-9]+[a-z]+"
        "msvc[rp][0-9]+(_([0-9]|codecvt_ids|atomic_wait))?"
        "vc([ao]mp|corlib|runtime)[0-9]+(_([0-9]|threads))?"
        "concrt[0-9]+"
        "pgort[0-9]+"
        "api-ms-win-[0-9a-z-]+")
    find "${1}" -iname '*.dll' | grep -Eif <(for m in "${ms[@]}"; do echo "/${m}[.]dll$"; done) | xargs -r rm
}

package() {
    local a="${pkgdir}/apps/${_realname}"
    mkdir -p "${a}"
    cp -R "snapshot"/* "${a}"
    mv "${a}/release"/* "${a}"
    rm -R "${a}/release"
    _rmmsdll "${a}"
}
