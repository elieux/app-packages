_extract_subdir() {
    local _file="$(get_filename "${1}")"
    local _dir="${_file%.*}"
    if type bsdtar | head -1 | grep -q 'is a function'
    then
        local _original_bsdtar="$(type bsdtar | tail +2)"
    fi
    bsdtar() {
        local _extra_args=()
        if [ "${1}" = "-xf" ]
        then
            mkdir -p "${_dir}"
            _extra_args=(-C "${_dir}")
        fi
        /usr/bin/bsdtar "${_extra_args[@]}" "${@}"
    }
    extract_file "${_file}"
    unset -f bsdtar
    eval "${_original_bsdtar}"
}

extract_https@subdir() {
    _extract_subdir "${@}"
}

download_https@subdir() {
    download_file "${1/@subdir:/:}"
}

_realname=google-cloud-cli
_choconame=gcloudsdk
pkgbase="app-${_realname}"
pkgname=("app-x86_64-${_realname}")
epoch=1
pkgver=562.0.0
pkgrel=1
pkgdesc="A set of command-line tools for the Google Cloud Platform"
url="https://cloud.google.com/cli/"
arch=('any')
license=('Apache-2.0')
provides=("${pkgbase}")
options=(!strip)
source=("google-cloud-cli-windows-x86_64.zip::https://storage.googleapis.com/cloud-sdk-release/google-cloud-cli-${pkgver}-windows-x86_64.zip")
sha512sums=('5721c28eb2aca79573e2df3b5c65c04e4d66479066ba3b3c08da52d6a2c4de545391a9cb46e22d6b40b5d4b982117df64d9b569391e6b79b699c4cfa0257df2f')

package() {
    local a="${pkgdir}/apps/${_realname}"
    mkdir -p "${a}"
    cp -R "google-cloud-sdk"/* "${a}"
}
