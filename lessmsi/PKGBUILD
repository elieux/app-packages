_extract_subdir() {
    local _file="$(get_filename "${1}")"
    local _dir="${_file%.*}"
    if type bsdtar | head -1 | grep -q 'is a function'
    then
        local _original_bsdtar="$(type bsdtar | tail +2)"
    fi
    bsdtar() {
        local _extra_args=()
        if [ "${1}" = "-xf" ]
        then
            mkdir -p "${_dir}"
            _extra_args=(-C "${_dir}")
        fi
        /usr/bin/bsdtar "${_extra_args[@]}" "${@}"
    }
    extract_file "${_file}"
    unset -f bsdtar
    eval "${_original_bsdtar}"
}

download_https@subdir() {
    download_file "${1/@subdir:/:}"
}

extract_https@subdir() {
    _extract_subdir "${@}"
}

_realname=lessmsi
_choconame=lessmsi
pkgbase="app-${_realname}"
pkgname=("app-i686-${_realname}")
epoch=1
pkgver=2.12.7
pkgrel=1
pkgdesc="A tool to view and extract the contents of a Windows Installer (.msi) file"
arch=('any')
url="https://lessmsi.activescott.com/"
license=('MIT')
provides=("${pkgbase}")
options=(!strip)
source=("lessmsi.zip::https@subdir://github.com/activescott/lessmsi/releases/download/v${pkgver}/lessmsi-v${pkgver}.zip")
sha512sums=('7be13be995dcaa45477e9ecb0393b9a50500bdce3a9a85c15407a35eb0bed09b09071b5331a294506d7dbae693a7ae87e63e4c02c5b87d195b24de7f77da5451')

package() {
    local a="${pkgdir}/apps/${_realname}"
    mkdir -p "${a}"
    cp -R "lessmsi"/* "${a}"
}
