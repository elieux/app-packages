_chocover() {
    # 1.12.0 -> 1.12
    echo "${1}" | sed -r 's/^([0-9]+)[.]([0-9]+)[.]0$/\1.\2/'
}

_realname=keepass-plugin-otp
_choconame=keepass-plugin-keepassotp
_dirname=keepass
pkgbase="app-${_realname}"
pkgname=("app-i686-${_realname}")
epoch=1
pkgver=1.12
pkgrel=1
pkgdesc="OTP support for KeePass"
url="https://github.com/Rookiestyle/KeePassOTP"
arch=('any')
license=('GPL3')
provides=("${pkgbase}")
options=(!strip)
source=("KeePassOTP.plgx::https://github.com/Rookiestyle/KeePassOTP/releases/download/v${pkgver}/KeePassOTP.plgx")
sha512sums=('5967ab3028ad6486ed223a17fee0b0043d163498b3644bd3dbc80098c4ab57bd93cd52d76366074cbb650c923d9c5c5d48e0b63ccd1c7673c66b9881599d125b')

package() {
    depends=("app-keepass")

    local a="${pkgdir}/apps/${_dirname}"
    mkdir -p "${a}/Plugins"
    cp "KeePassOTP.plgx" "${a}/Plugins"
}
