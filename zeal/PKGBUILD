# Maintainer: David Macek <david.macek.0@gmail.com>

_realname=zeal
_choconame=zeal
pkgbase="app-${_realname}"
pkgname=("app-x86_64-${_realname}")
epoch=1
pkgver=0.8.0
pkgrel=1
pkgdesc="An offline documentation browser for software developers"
url="https://zealdocs.org/"
arch=('any')
license=('GPL3')
replaces=("app-i686-${_realname}")
makedepends=("app-lessmsi")
provides=("${pkgbase}")
options=(!strip)
source=("zeal-windows-x64.msi::https://github.com/zealdocs/zeal/releases/download/v${pkgver}/zeal-${pkgver}-windows-x64.msi")
sha512sums=('2d787b40b85c32fdaa717eb8bf90bc47d459b35726ef0b457dd0289e8755e6e7d8f0330b0356bdeb2b95b4c586f50bcf07e1bd0f52ff4b009ea6566c84fa802f')

_lc() {
    local d f n

    for f in "${@}"
    do
        d="$(dirname "${f}")"
        f="$(basename "${f}")"
        n="$(echo "${f}" | tr 'A-Z' 'a-z')"
        if test "${f}" != "${n}"
        then
            mv "${d}/${f}" "${d}/${n}"
        fi
    done
}

prepare() {
    rm -fR "zeal-windows-x64"
    /apps/lessmsi/lessmsi x "zeal-windows-x64.msi" > /dev/null
}

package() {
    local a="${pkgdir}/apps/${_realname}"
    mkdir -p "${a}"
    cp -R "zeal-windows-x64/SourceDir/Zeal"/* "${a}"
    _lc "${a}"/*
}
