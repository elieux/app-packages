_chocover() {
    # 1.16 -> 1.16.0
    echo "${1}" | sed -r 's/^([0-9]+)[.]([0-9]+)$/\1.\2.0/'
}

_extract_subdir() {
    local _file="$(get_filename "${1}")"
    local _dir="${_file%.*}"
    if type bsdtar | head -1 | grep -q 'is a function'
    then
        local _original_bsdtar="$(type bsdtar | tail +2)"
    fi
    bsdtar() {
        local _extra_args=()
        if [ "${1}" = "-xf" ]
        then
            mkdir -p "${_dir}"
            _extra_args=(-C "${_dir}")
        fi
        /usr/bin/bsdtar "${_extra_args[@]}" "${@}"
    }
    extract_file "${_file}"
    unset -f bsdtar
    eval "${_original_bsdtar}"
}

download_https@subdir() {
    download_file "${1/@subdir:/:}"
}

extract_https@subdir() {
    _extract_subdir "${@}"
}

_realname=coretemp
_choconame=coretemp
pkgbase="app-${_realname}"
pkgname=("app-x86_64-${_realname}")
epoch=1
pkgver=1.20.0.145
pkgrel=1
pkgdesc="A compact program to monitor processor temperature"
arch=('any')
url="https://www.alcpu.com/CoreTemp/"
license=('custom')
replaces=("app-i686-${_realname}")
provides=("${pkgbase}")
options=(!strip)
source=("CoreTemp64.zip::https@subdir://www.alcpu.com/CoreTemp/CoreTemp64.zip"
        "CoreTempTranslator.zip::https@subdir://www.alcpu.com/CoreTemp/CoreTempTranslator.zip")
sha512sums=('33c24a652721762fe326c5a063e7fa2084c437a55d6f6adfcb9c63f41da4269aef90e2def2593c81b5bda3debe0a20a0ecc95d7f47b571c12d585078535bdaa6'
            '695f0f33abab0024a866a92478779abb9060b4a411057d9cf394a40b88d0f99634d8200e5beb2400798ebf225fed9a8974aedd91ccccb2a781c3f5373013ef12')

_lc() {
    local d f n

    for f in "${@}"
    do
        d="$(dirname "${f}")"
        f="$(basename "${f}")"
        n="$(echo "${f}" | tr 'A-Z' 'a-z')"
        if test "${f}" != "${n}"
        then
            mv "${d}/${f}" "${d}/${n}"
        fi
    done
}

pkgver() {
    powershell -command '(Get-Item "CoreTemp64/Core Temp.exe").VersionInfo.ProductVersion' | sed -r 's/([0-9]+[.][0-9]+[.][0-9]+)[.]0$/\1/'
}

package() {
    local a="${pkgdir}/apps/${_realname}"
    mkdir -p "${a}" "${a}/translator"
    cp -R "CoreTemp64"/* "${a}"
    mv "${a}/Core Temp.exe" "${a}/CoreTemp.exe"
    cp -R "CoreTempTranslator"/* "${a}/translator"
    mv "${a}/translator"/{languages,CoreTempTranslator.exe,Logger.dll} "${a}"
    mv "${a}/translator/en-US.lng" "${a}/languages/en-US.lng"
    _lc "${a}"/*
}
