# Maintainer: David Macek <david.macek.0@gmail.com>

_realname=1password
_choconame=1password
pkgbase="app-${_realname}"
pkgname=("app-x86_64-${_realname}")
epoch=1
pkgver=8.12.10.36
pkgrel=1
pkgdesc="Password manager and secure wallet"
url="https://1password.com/downloads"
arch=('any')
license=('custom')
makedepends=("app-lessmsi")
provides=("${pkgbase}")
options=(!strip)
source=("1PasswordSetup-latest.msi::https://downloads.1password.com/win/1PasswordSetup-latest.msi")
sha512sums=('20b0b4f933fa9226159fe679c4290da899760cc2ab16cc03341243585ae7d94e618213e131374ab4d162fc81286134c3400862e45c90d2ddc7b7da60f25387a4')
noextract=("1PasswordSetup-latest.exe")

_lc() {
    local d f n

    for f in "${@}"
    do
        d="$(dirname "${f}")"
        f="$(basename "${f}")"
        n="$(echo "${f}" | tr 'A-Z' 'a-z')"
        if test "${f}" != "${n}"
        then
            mv "${d}/${f}" "${d}/${n}"
        fi
    done
}

prepare() {
    rm -fR "1PasswordSetup-latest"
    /apps/lessmsi/lessmsi x "1PasswordSetup-latest.msi" > /dev/null
}

pkgver() {
    powershell -command '(Get-Item "1PasswordSetup-latest/SourceDir/ProgramFiles64Folder/1Password/app/8/1Password.exe").VersionInfo.FileVersion'
}

package() {
    local a="${pkgdir}/apps/${_realname}"
    mkdir -p "${a}"
    cp -R "1PasswordSetup-latest/SourceDir/ProgramFiles64Folder/1Password/app/8"/* "${a}"
    _lc "${a}"/*
}
