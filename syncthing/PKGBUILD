_realname=syncthing
_choconame=syncthing
pkgbase="app-${_realname}"
pkgname=("app-x86_64-${_realname}")
epoch=1
pkgver=2.0.15
pkgrel=1
pkgdesc="Continuous file synchronization"
url="https://syncthing.net/"
arch=('any')
license=('MPL')
provides=("${pkgbase}")
options=(!strip)
source=("syncthing-windows-amd64.zip::https://github.com/syncthing/syncthing/releases/download/v${pkgver}/syncthing-windows-amd64-v${pkgver}.zip")
sha512sums=('a89321b62d328a28ef2ae2dcada93c20d3cb16465587bde2ce40ad1d20686b16652ec404bb12cf26e8035392024d7c70268304b6cd453a093fe3e2a5e94bdde7')

package() {
    local a="${pkgdir}/apps/${_realname}"
    mkdir -p "${a}"
    cp -R "syncthing-windows-amd64-v${pkgver}"/* "${a}"
}
